{
  "expo": {
    "name": "GoBaby Travel",
    "slug": "gobaby-travel",
    "version": "2.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "gobaby-travel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gobaby.travel",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Get personalized travel deals and trip reminders",
        "NSLocationWhenInUseUsageDescription": "Get smarter travel recommendations nearby",
        "NSCameraUsageDescription": "Scan documents and capture travel moments",
        "NSPhotoLibraryUsageDescription": "Upload travel documents and photos easily",
        "NSMicrophoneUsageDescription": "Use voice features for hands-free planning",
        "NSContactsUsageDescription": "Share trips with your travel companions"
      }
    },
    "android": {
      "package": "com.gobaby.travel",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "RECORD_AUDIO",
        "READ_CONTACTS"
      ],
      "versionCode": 4
    },
    "web": {
      "bundler": "metro",
      "output": "single-page",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#060f20"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30cda0e7-992d-46aa-9fca-97651099366d"
      }
    },
    "owner": "gobabytravel",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/30cda0e7-992d-46aa-9fca-97651099366d"
    }
  }
}
